{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillInspectorReport",
  "type": "object",
  "required": [
    "summary",
    "workflow",
    "translation",
    "references",
    "safety",
    "install",
    "score",
    "suggestions",
    "source"
  ],
  "properties": {
    "summary": {
      "type": "object",
      "required": ["title", "purpose", "score_total", "risk_level"],
      "properties": {
        "title": { "type": "string" },
        "purpose": { "type": "string" },
        "score_total": { "type": "number" },
        "risk_level": { "type": "string" }
      }
    },
    "workflow": {
      "type": "object",
      "required": ["caption", "nodes", "edges"],
      "properties": {
        "mermaid": { "type": "string" },
        "caption": { "type": "string" }
        ,
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "kind": { "type": "string" }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        }
      }
    },
    "translation": {
      "type": "object",
      "required": ["mode", "sections"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["compact", "full"]
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title_zh", "title_en", "rows"],
            "properties": {
              "title_zh": { "type": "string" },
              "title_en": { "type": "string" },
              "rows": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["zh", "en"],
                  "properties": {
                    "zh": { "type": "string" },
                    "en": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target", "kind", "summary", "condition", "line"],
        "properties": {
          "target": { "type": "string" },
          "kind": { "type": "string" },
          "summary": { "type": "string" },
          "condition": { "type": ["string", "null"] },
          "line": { "type": "string" }
        }
      }
    },
    "safety": {
      "type": "object",
      "required": ["level_code", "level_label", "level_summary", "findings"],
      "properties": {
        "level_code": { "type": "string" },
        "level_label": { "type": "string" },
        "level_summary": { "type": "string" },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["signal", "severity", "meaning", "evidence"],
            "properties": {
              "signal": { "type": "string" },
              "severity": { "type": "string" },
              "meaning": { "type": "string" },
              "evidence": { "type": "string" }
            }
          }
        }
      }
    },
    "install": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["platform", "status"],
            "properties": {
              "platform": { "type": "string" },
              "status": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        }
      }
    },
    "score": {
      "type": "object",
      "required": ["dimensions"],
      "properties": {
        "dimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value", "rationale"],
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "number" },
              "rationale": { "type": "string" }
            }
          }
        }
      }
    },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "detail", "priority"],
        "properties": {
          "title": { "type": "string" },
          "detail": { "type": "string" },
          "priority": { "type": "string" }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["primary_label", "primary_value"],
      "properties": {
        "primary_label": { "type": "string" },
        "primary_value": { "type": "string" }
      }
    }
  }
}
